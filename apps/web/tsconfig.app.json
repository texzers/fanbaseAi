{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "paths": {
      "@fanpulse/shared-types": ["../../packages/shared-types/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/tests/**/*", "src/**/*.test.ts", "src/**/*.test.tsx", "src/tests/setup.ts"]
}
