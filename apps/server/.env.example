# FanPulse AI — Server Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign JWTs. Use a long, random string in production.
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
# JWT token expiry (e.g., "7d", "24h", "30m")
JWT_EXPIRES_IN=24h

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to server root or absolute).
DATABASE_URL=./data/fanpulse.db

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Your Anthropic API key — NEVER expose this to the frontend.
# The backend acts as a secure proxy for all GenAI requests.
ANTHROPIC_API_KEY=sk-ant-replace-with-your-actual-key

# Model to use for all GenAI calls.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum requests per window per IP on AI-heavy endpoints.
RATE_LIMIT_MAX_REQUESTS=30
# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed frontend origin(s). Comma-separated for multiple.
CORS_ORIGIN=http://localhost:5173

# ── Crowd Simulator ───────────────────────────────────────────────────────────
# How often (ms) the crowd simulator ticks to update density values.
# Default: 10000 (10 seconds)
SIMULATOR_TICK_MS=10000
